{
  "name": "criptis",
  "version": "1.0.0",
  "private": true,
  "description": "Crypto price watcher on GitHub Actions — deterministic triggers, LLM analysis, email alerts via Resend",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "watch": "node watcher.js",
    "dry-run": "node watcher.js --dry-run",
    "trader": "node trader.js",
    "trader:dry": "node trader.js --dry-run",
    "backtest": "node backtest/run.mjs",
    "forecast": "node forecast.js",
    "forecast:dry": "node forecast.js --dry-run",
    "test": "node --test"
  }
}
